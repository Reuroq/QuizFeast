{
  "name": "quizfeast",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:prod": "PLAYWRIGHT_BASE_URL=https://quizfeast.com playwright test",
    "test:smoke": "node tests/smoke.mjs",
    "test:journeys": "playwright test --config=playwright.journeys.config.js",
    "test:journeys:prod": "PLAYWRIGHT_BASE_URL=https://quizfeast.com playwright test --config=playwright.journeys.config.js",
    "audit": "node scripts/audit/run.mjs",
    "audit:fast": "AUDIT_AGENTS=functional,legal,launch node scripts/audit/run.mjs",
    "audit:perf": "AUDIT_AGENTS=lighthouse,load node scripts/audit/run.mjs",
    "audit:autofix": "AUDIT_AUTO_FIX=1 node scripts/audit/run.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@pinecone-database/pinecone": "^2.2.0",
    "autoprefixer": "^10.4.0",
    "framer-motion": "^11.0.0",
    "mammoth": "^1.7.0",
    "next": "^14.2.0",
    "openai": "^4.50.0",
    "pdf-parse": "^1.1.1",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "chrome-launcher": "^1.2.1",
    "fast-xml-parser": "^5.8.0",
    "lighthouse": "^13.3.0"
  }
}
